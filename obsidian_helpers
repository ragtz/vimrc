#!/bin/bash

# ---------------------------------------------------------------------------
# daily: work with sections of today's Obsidian daily note.
#
#   daily                             -> create/open today's note
#   daily recap                       -> full note (numbered lists)
#   daily <section> recap             -> one section (falls back to full note)
#   daily <section> mark <i...> <state>  state: in-progress|done|check|forward|cancel|important|uncheck
#   daily <section> add <checkbox|bullet> "text" [--tag <tag>] [--link <note>]
#   daily <section> delete <i...>
#
# <section> matches a heading (any level) by case-insensitive substring.
# <i...> are one or more list-item numbers as shown by recap (per-list, 1-based).
# Checkbox glyphs follow Obsidian's convention:
#   done -> [x]  in-progress -> [/]  forward -> [>]  cancel -> [-]  important -> [!]
# Override the target file with $DAILY_NOTE.
# ---------------------------------------------------------------------------

_daily_file() {
    if [ -n "$DAILY_NOTE" ]; then printf '%s\n' "$DAILY_NOTE"; return 0; fi
    local vault rel file
    vault="$(obsidian vault 2>/dev/null | awk -F'\t' '$1=="path"{print $2}')"
    rel="$(obsidian daily:path 2>/dev/null)"
    [ -n "$vault" ] && [ -n "$rel" ] || { echo "daily: could not resolve daily note path" >&2; return 1; }
    file="$vault/$rel"
    [ -f "$file" ] || { echo "daily: no daily note at $file" >&2; return 1; }
    printf '%s\n' "$file"
}

_daily_ensure_file() {
    if [ -n "$DAILY_NOTE" ]; then printf '%s\n' "$DAILY_NOTE"; return 0; fi
    local vault rel file
    vault="$(obsidian vault 2>/dev/null | awk -F'\t' '$1=="path"{print $2}')"
    rel="$(obsidian daily:path 2>/dev/null)"
    [ -n "$vault" ] && [ -n "$rel" ] || { echo "daily: could not resolve daily note path" >&2; return 1; }
    file="$vault/$rel"
    if [ ! -f "$file" ]; then
        obsidian daily >/dev/null 2>&1        # Obsidian creates (and opens) today's note
        local i=0
        while [ ! -f "$file" ] && [ "$i" -lt 20 ]; do sleep 0.1; i=$((i+1)); done
    fi
    [ -f "$file" ] || { echo "daily: could not create daily note at $file" >&2; return 1; }
    printf '%s\n' "$file"
}

# Resolve a daily note by day offset (0=today, -1=yesterday, ...), read-only.
# Offset 0 delegates to _daily_file (honors $DAILY_NOTE); past notes are located
# by date and never created. Assumes YYYY-MM-DD.md daily-note filenames.
_daily_file_offset() {
    local off="$1"
    if [ "$off" -eq 0 ]; then _daily_file; return; fi
    local vault rel dir base today date file
    vault="$(obsidian vault 2>/dev/null | awk -F'\t' '$1=="path"{print $2}')"
    rel="$(obsidian daily:path 2>/dev/null)"
    [ -n "$vault" ] && [ -n "$rel" ] || { echo "daily: could not resolve daily note path" >&2; return 1; }
    dir="$(dirname "$rel")"; base="$(basename "$rel" .md)"
    today="$(date +%F)"
    [ "$base" = "$today" ] || { echo "daily: daily-note name '$base' is not YYYY-MM-DD; offset lookups unsupported" >&2; return 1; }
    date="$(date -d "$off day" +%F)" || return 1
    if [ "$dir" = "." ]; then file="$vault/$date.md"; else file="$vault/$dir/$date.md"; fi
    [ -f "$file" ] || { echo "daily: no daily note for $date at $file" >&2; return 1; }
    printf '%s\n' "$file"
}

# Insert a "## <heading>" line if the section is absent, keeping the managed
# sections in canonical order (todo -> done -> notes) regardless of the order
# the daily-* commands run. A new heading goes immediately before the first
# existing section that outranks it; with no higher-ranked section it is
# appended at end. Rank comes from the heading text via the same case-insensitive
# substring rule the verbs use, so "## Done" still matches the `done` verb.
_daily_ensure_section() {
    local file="$1" heading="$2"
    local tmp; tmp="$(mktemp)"
    HEADING="$heading" awk '
        function trim(s){ gsub(/^[[:space:]]+|[[:space:]]+$/,"",s); return s }
        function hrank(t,  lt){ lt=tolower(trim(t))
            if(index(lt,"todo")>0)  return 1
            if(index(lt,"done")>0)  return 2
            if(index(lt,"notes")>0) return 3
            return 0 }
        BEGIN{ heading=ENVIRON["HEADING"]; rank=hrank(heading) }
        { lines[NR]=$0 }
        /^#{1,6}[[:space:]]/{
            match($0,/^#+/)
            if(hrank(substr($0,RLENGTH+1))==rank) exists=1
        }
        END{
            if(exists){ for(i=1;i<=NR;i++) print lines[i]; exit }
            for(i=1;i<=NR;i++){
                if(!inserted && lines[i] ~ /^#{1,6}[[:space:]]/){
                    match(lines[i],/^#+/)
                    if(hrank(substr(lines[i],RLENGTH+1))>rank){
                        if(i>1 && lines[i-1] !~ /^[[:space:]]*$/) print ""
                        print "## " heading; print ""
                        inserted=1
                    }
                }
                print lines[i]
            }
            if(!inserted){
                if(NR>0 && lines[NR] !~ /^[[:space:]]*$/) print ""
                print "## " heading
            }
        }
    ' "$file" > "$tmp"
    cat "$tmp" > "$file" && rm -f "$tmp"
}

_daily_usage() {
    cat >&2 <<'EOF'
usage:
  daily
  daily recap
  daily <section> recap
  daily <section> mark <index...> <in-progress|done|check|forward|cancel|important|uncheck>
  daily <section> add <checkbox|bullet> "text" [--tag <tag>] [--link <note>]
  daily <section> delete <index...>
EOF
}

_daily_recap() {
    local file="$1" section="$2" note out result
    note="$(cat "$file")" || return 1

    result="$note"
    if [ -n "$section" ]; then
        out="$(printf '%s\n' "$note" | awk -v want="$section" '
            function trim(s) { gsub(/^[[:space:]]+|[[:space:]]+$/, "", s); return s }
            BEGIN { want = tolower(trim(want)); level = 0; grab = 0 }
            /^#{1,6}[[:space:]]/ {
                match($0, /^#+/); h = RLENGTH; text = substr($0, h + 1)
                if (grab && h <= level) grab = 0
                if (!grab && index(tolower(trim(text)), want) > 0) { grab = 1; level = h; print; next }
            }
            grab { print }
        ')"
        [ -n "$out" ] && result="$out"
    fi

    if printf '%s\n' "$result" | grep -qE '^[[:space:]]*([-*+]|[0-9]+[.)])[[:space:]]'; then
        printf '%s\n' "$result" | awk '
            /^[[:space:]]*([-*+]|[0-9]+[.)])[[:space:]]/ {
                line = $0
                sub(/^[[:space:]]*([-*+]|[0-9]+[.)])[[:space:]]+/, "", line)
                printf "  %d. %s\n", ++n, line; next
            }
            { n = 0; print }
        '
    else
        printf '%s\n' "$result"
    fi
}

_daily_mark() {
    local file="$1" section="$2"; shift 2
    # trailing arg is the target state; every arg before it is a list index
    if [ "$#" -lt 2 ]; then _daily_usage; return 2; fi
    local status="${@: -1}"
    local idxs=( "${@:1:$#-1}" )
    local i
    for i in "${idxs[@]}"; do
        case "$i" in ''|*[!0-9]*) echo "daily: index must be a positive integer" >&2; return 2 ;; esac
    done

    local mark
    case "$status" in
        done|check)  mark='x' ;;
        in-progress) mark='/' ;;
        forward)     mark='>' ;;
        cancel)      mark='-' ;;
        important)   mark='!' ;;
        uncheck)     mark=' ' ;;
        *) echo "daily: state must be one of in-progress, done, check, forward, cancel, important, uncheck" >&2; return 2 ;;
    esac

    local tmp; tmp="$(mktemp)"
    WANT="$section" IDXS="${idxs[*]}" MARK="$mark" awk '
        function trim(s){ gsub(/^[[:space:]]+|[[:space:]]+$/,"",s); return s }
        BEGIN{ want=tolower(trim(ENVIRON["WANT"])); mark=ENVIRON["MARK"]
               ni=split(ENVIRON["IDXS"], a, " "); for(i=1;i<=ni;i++) target[a[i]+0]=1
               grab=0; entered=0; level=0; n=0; found=0; marked=0 }
        /^#{1,6}[[:space:]]/{
            match($0,/^#+/); h=RLENGTH; text=substr($0,h+1)
            if(grab && h<=level) grab=0
            if(!entered && !grab && index(tolower(trim(text)),want)>0){ grab=1; entered=1; found=1; level=h; n=0 }
            print; next
        }
        {
            if(grab){
                if($0 ~ /^[[:space:]]*([-*+]|[0-9]+[.)])[[:space:]]/){
                    if(++n in target){
                        line=$0
                        if(line ~ /^[[:space:]]*([-*+]|[0-9]+[.)])[[:space:]]+\[.\]/)
                            sub(/\[.\]/, "[" mark "]", line)
                        else if(line ~ /^[[:space:]]*[-*+][[:space:]]+/)
                            sub(/^[[:space:]]*[-*+][[:space:]]+/, "&[" mark "] ", line)
                        else
                            sub(/^[[:space:]]*[0-9]+[.)][[:space:]]+/, "&[" mark "] ", line)
                        print line; marked++; next
                    }
                } else n=0
            }
            print
        }
        END{ if(!found) exit 3; if(!marked) exit 4 }
    ' "$file" > "$tmp"
    local rc=$?
    case "$rc" in
        0) cat "$tmp" > "$file" && rm -f "$tmp" ;;
        3) rm -f "$tmp"; echo "daily: no section matching '$section' found" >&2; return 3 ;;
        4) rm -f "$tmp"; echo "daily: no list items (${idxs[*]}) under '$section'" >&2; return 4 ;;
        *) rm -f "$tmp"; echo "daily: failed to process note" >&2; return 1 ;;
    esac
}

_daily_delete() {
    local file="$1" section="$2"; shift 2
    if [ "$#" -lt 1 ]; then _daily_usage; return 2; fi
    local i
    for i in "$@"; do
        case "$i" in ''|*[!0-9]*) echo "daily: index must be a positive integer" >&2; return 2 ;; esac
    done

    # Number list items by their original position and drop the targeted ones in
    # a single pass, so deleting several at once doesn't shift indices mid-run.
    local tmp; tmp="$(mktemp)"
    WANT="$section" IDXS="$*" awk '
        function trim(s){ gsub(/^[[:space:]]+|[[:space:]]+$/,"",s); return s }
        BEGIN{ want=tolower(trim(ENVIRON["WANT"]))
               ni=split(ENVIRON["IDXS"], a, " "); for(i=1;i<=ni;i++) target[a[i]+0]=1
               grab=0; entered=0; level=0; n=0; found=0; deleted=0 }
        /^#{1,6}[[:space:]]/{
            match($0,/^#+/); h=RLENGTH; text=substr($0,h+1)
            if(grab && h<=level) grab=0
            if(!entered && !grab && index(tolower(trim(text)),want)>0){ grab=1; entered=1; found=1; level=h; n=0 }
            print; next
        }
        {
            if(grab){
                if($0 ~ /^[[:space:]]*([-*+]|[0-9]+[.)])[[:space:]]/){
                    if(++n in target){ deleted++; next }
                } else n=0
            }
            print
        }
        END{ if(!found) exit 3; if(!deleted) exit 4 }
    ' "$file" > "$tmp"
    local rc=$?
    case "$rc" in
        0) cat "$tmp" > "$file" && rm -f "$tmp" ;;
        3) rm -f "$tmp"; echo "daily: no section matching '$section' found" >&2; return 3 ;;
        4) rm -f "$tmp"; echo "daily: no list items ($*) under '$section'" >&2; return 4 ;;
        *) rm -f "$tmp"; echo "daily: failed to process note" >&2; return 1 ;;
    esac
}

_daily_add() {
    local file="$1" section="$2"; shift 2
    local type="$1"; shift
    case "$type" in checkbox|bullet) ;; *) echo "daily: add type must be 'checkbox' or 'bullet'" >&2; return 2 ;; esac

    local text="" tag="" link=""
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --tag)  tag="$2";  shift 2 ;;
            --link) link="$2"; shift 2 ;;
            *) text="${text:+$text }$1"; shift ;;
        esac
    done
    [ -n "$text" ] || { echo "daily: add requires text" >&2; return 2; }

    local marker prefix=""
    case "$type" in checkbox) marker='- [ ]' ;; bullet) marker='-' ;; esac
    if [ -n "$link" ]; then link="${link#\[\[}"; link="${link%\]\]}"; prefix="[[${link}]] "; fi
    [ -n "$tag" ] && prefix="${prefix}#${tag#\#} "
    local content="$marker ${prefix}$text"

    local tmp; tmp="$(mktemp)"
    WANT="$section" ADD="$content" awk '
        function trim(s){ gsub(/^[[:space:]]+|[[:space:]]+$/,"",s); return s }
        function flush(){ print ENVIRON["ADD"]; for(i=1;i<=np;i++) print pend[i]; np=0; grab=0 }
        BEGIN{ want=tolower(trim(ENVIRON["WANT"])); grab=0; done=0; level=0; np=0; found=0 }
        /^#{1,6}[[:space:]]/{
            match($0,/^#+/); h=RLENGTH; text=substr($0,h+1)
            if(grab && h<=level) flush()
            if(!done && !grab && index(tolower(trim(text)),want)>0){ grab=1; found=1; level=h; print; next }
            print; next
        }
        {
            if(grab){
                if($0 ~ /^[[:space:]]*$/){ pend[++np]=$0; next }
                for(i=1;i<=np;i++) print pend[i]; np=0; print; next
            }
            print
        }
        END{ if(grab) flush(); if(!found) exit 3 }
    ' "$file" > "$tmp"
    local rc=$?
    if [ "$rc" -eq 3 ]; then
        printf '\n## %s\n%s\n' "$section" "$content" >> "$tmp"
    elif [ "$rc" -ne 0 ]; then
        rm -f "$tmp"; echo "daily: failed to process note" >&2; return 1
    fi
    cat "$tmp" > "$file" && rm -f "$tmp"
}

daily() {
    # bare `daily` -> create/open today's daily note
    if [ "$#" -eq 0 ]; then
        obsidian daily
        return
    fi

    local file; file="$(_daily_file)" || return 1

    if [ "$#" -eq 1 ] && [ "$1" = "recap" ]; then
        _daily_recap "$file" ""; return
    fi

    local section="$1" verb="$2"
    if [ -z "$section" ] || [ -z "$verb" ]; then _daily_usage; return 2; fi
    shift 2

    case "$verb" in
        recap) _daily_recap "$file" "$section" ;;
        mark)   _daily_mark   "$file" "$section" "$@" ;;
        add)    _daily_add    "$file" "$section" "$@" ;;
        delete) _daily_delete "$file" "$section" "$@" ;;
        *) echo "daily: unknown verb '$verb'" >&2; _daily_usage; return 2 ;;
    esac
}

# Split wrapper args into note text and an optional wiki-link, using a bare
# `@` sigil: everything after the first `@`-token runs to end-of-line as the
# link (spaces allowed, no quotes); text is everything before it. Sets _TEXT
# and _LINK in the caller's scope. `@Foo Bar` and `@ Foo Bar` both work.
_daily_split() {
  _TEXT=""; _LINK=""
  local in_link=0 w
  for w in "$@"; do
    if [ "$in_link" -eq 0 ] && [ "${w#@}" != "$w" ]; then
      in_link=1; _LINK="${w#@}"
    elif [ "$in_link" -eq 1 ]; then
      _LINK="${_LINK:+$_LINK }$w"
    else
      _TEXT="${_TEXT:+$_TEXT }$w"
    fi
  done
}

# Render a recap through mdviewer. mdviewer natively rewrites [[wiki-links]]
# to markdown links, but for multi-word names it emits an unescaped space in
# the URL (e.g. [Manip Retool](./Manip Retool.md)), which CommonMark rejects,
# so the link shows as literal text. Pre-convert the wiki-links ourselves to a
# link with a "#" target: mdviewer keeps the link styling on the name but shows
# no ".md" URL. (Delimiter is ~ since the replacement contains #.)
#
# The recap numbers checkbox items as "  N. [ ] text". mdviewer treats a
# leading [ ]/[x] as a GFM task-list item and renders a checkbox glyph in
# place of the ordinal N, so the number vanishes for unchecked/done items
# (the Obsidian-only states [/] [>] [-] [!] aren't task syntax, so they keep
# their number). Escape the checkbox bracket so mdviewer leaves it as literal
# text and always shows the ordinal.
_daily_view() {
  sed -E \
    -e 's~^([[:space:]]*[0-9]+\.[[:space:]]+)\[(.)\]~\1\\[\2\\]~' \
    -e 's~\[\[([^]|]+)\|([^]]+)\]\]~[\2](#)~g' \
    -e 's~\[\[([^]]+)\]\]~[\1](#)~g' \
  | mdviewer
}

daily-done() {
  local file; file="$(_daily_ensure_file)" || return 1
  _daily_ensure_section "$file" Done

  if [[ $# -ge 1 ]]; then
    local _TEXT _LINK
    # <verb> <i...>: first arg is a verb only when the second arg is a number
    # (the remaining args are treated as additional indices).
    if [[ $1 == del && $2 =~ ^[0-9]+$ ]]; then
      daily done delete "${@:2}"
    else
      _daily_split "$@"
      daily done add bullet "$_TEXT" ${_LINK:+--link "$_LINK"}
    fi
  fi

  daily done recap | _daily_view
}

daily-note() {
  local file; file="$(_daily_ensure_file)" || return 1
  _daily_ensure_section "$file" Notes

  if [[ $# -ge 1 ]]; then
    local _TEXT _LINK
    # <verb> <i...>: first arg is a verb only when the second arg is a number
    # (the remaining args are treated as additional indices).
    if [[ $1 == del && $2 =~ ^[0-9]+$ ]]; then
      daily notes delete "${@:2}"
    else
      _daily_split "$@"
      daily notes add bullet "$_TEXT" ${_LINK:+--link "$_LINK"}
    fi
  fi

  daily notes recap | _daily_view
}

daily-todo() {
  local file; file="$(_daily_ensure_file)" || return 1
  _daily_ensure_section "$file" Todo

  if [[ $# -ge 1 ]]; then
    local _TEXT _LINK verb=""
    # <verb> <i...>: first arg is a verb only when the second arg is a number
    # (the remaining args are treated as additional indices).
    if [[ $2 =~ ^[0-9]+$ ]]; then
      case $1 in
        del)                                               verb=del ;;
        done|check|in-progress|forward|cancel|important|uncheck) verb=mark ;;
      esac
    fi

    case $verb in
      del)  daily todo delete "${@:2}" ;;
      mark) daily todo mark "${@:2}" "$1" ;;
      *)    _daily_split "$@"
            daily todo add checkbox "$_TEXT" ${_LINK:+--link "$_LINK"} ;;
    esac
  fi

  daily todo recap | _daily_view
}

# daily-recap [<offset>|yester|ere]
#   no arg / 0 / today   -> today's note
#   -N                   -> N days ago (-1 = yesterday, -2 = the day before, ...)
#   yester | yesterday   -> -1
#   ere | ereyesterday   -> -2
daily-recap() {
  local off
  case "${1-}" in
    ''|0|today)        off=0 ;;
    yester|yesterday)  off=-1 ;;
    ere|ereyesterday)  off=-2 ;;
    *) if [[ $1 =~ ^-[0-9]+$ ]]; then off=$1
       else echo "daily-recap: expected a negative day offset (e.g. -1), or yester/ere" >&2; return 2; fi ;;
  esac

  local file; file="$(_daily_file_offset "$off")" || return 1
  _daily_recap "$file" "" | _daily_view
}

dtodo() {
  daily-todo $@
}

ddone() {
  daily-done $@
}

dnote() {
  daily-note $@
}

drecap() {
  daily-recap $@
}
